# EdgeFlow Backend Environment Variables
# Copy this file to .env and adjust as needed.

NODE_ENV=development
PORT=4000
HOST=0.0.0.0
API_PREFIX=/api/v1
GATEWAY_PREFIX=/gateway
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
BODY_LIMIT=1mb

DATABASE_URL=postgresql://edgeflow:edgeflow@localhost:5432/edgeflow
DB_HOST=localhost
DB_PORT=5432
DB_NAME=edgeflow
DB_USER=edgeflow
DB_PASSWORD=edgeflow
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONN_TIMEOUT_MS=5000

REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=edgeflow:
REDIS_DEFAULT_TTL=60

JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=edgeflow
JWT_AUDIENCE=edgeflow-dashboard

BCRYPT_SALT_ROUNDS=12

RATE_LIMIT_WINDOW_SEC=60
RATE_LIMIT_MAX=100
RATE_LIMIT_HOUR_MAX=5000

GATEWAY_TIMEOUT_MS=30000
GATEWAY_MAX_RETRIES=1
GATEWAY_RETRY_DELAY_MS=200

CB_FAILURE_THRESHOLD=5
CB_SUCCESS_THRESHOLD=2
CB_OPEN_MS=30000
CB_HALF_OPEN_MAX=3

HEALTH_CHECK_INTERVAL_MS=30000
HEALTH_CHECK_TIMEOUT_MS=5000
UNHEALTHY_THRESHOLD=3

LOG_LEVEL=info
LOG_FORMAT=pretty

SEED_ADMIN_EMAIL=xyz
SEED_ADMIN_PASSWORD=xyz
SEED_ADMIN_NAME=xyz
