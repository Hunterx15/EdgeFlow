# EdgeFlow - Root Environment Variables
# Copy to .env and override as needed. Backend and frontend have their
# own .env.example files in their respective directories.

# Backend
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

DATABASE_URL=postgresql://edgeflow:edgeflow@localhost:5432/edgeflow
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=true

JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string

SEED_ADMIN_EMAIL=admin@edgeflow.dev
SEED_ADMIN_PASSWORD=Admin@12345
SEED_ADMIN_NAME=EdgeFlow Admin

# Frontend
VITE_API_BASE_URL=/api/v1
VITE_API_URL=http://localhost:4000
